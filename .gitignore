limport numpy as np

class LatticeGenerator:
    def __init__(self, resolution=50):
        self.res = resolution
        self.grid = np.linspace(-np.pi, np.pi, self.res)
        self.X, self.Y, self.Z = np.meshgrid(self.grid, self.grid, self.grid)

    def create_gyroid(self, thickness=0.2):
        """Mathematical modeling of bone-like micro-structures"""
        # Gyroid Equation: sin(x)cos(y) + sin(y)cos(z) + cos(x)sin(z)
        gyroid = (np.sin(self.X) * np.cos(self.Y) + 
                  np.sin(self.Y) * np.cos(self.Z) + 
                  np.cos(self.X) * np.sin(self.Z))
        
        # Define the solid boundaries of the lattice
        lattice = np.abs(gyroid) < thickness
        porosity = 1 - (np.sum(lattice) / self.res**3)
        return lattice, porosity

# Usage for Slide 9 (Implementation)
gen = LatticeGenerator()
structure, porosity = gen.create_gyroid(thickness=0.15)
print(f"Lattice Generated. Calculated Porosity: {porosity*100:.2f}%")
