import random

class SmartImplantSystem:
    def __init__(self):
        self.integrity = 100.0 # Percentage
        self.healing_reservoir = 100.0 # ml

    def simulate_stress_event(self):
        damage = random.uniform(5, 20)
        self.integrity -= damage
        print(f"CRACK DETECTED: Integrity dropped to {self.integrity:.1f}%")
        
        if self.integrity < 95:
            self.trigger_healing()

    def trigger_healing(self):
        if self.healing_reservoir >= 10:
            print("Action: Rupturing micro-capsules... releasing resin.")
            self.healing_reservoir -= 10
            self.integrity += (100 - self.integrity) * 0.9 # 90% recovery
            print(f"HEALING COMPLETE: Integrity restored to {self.integrity:.1f}%")
        else:
            print("ERROR: Healing agent depleted.")

# Usage for Slide 12 (Challenges/Results)
implant = SmartImplantSystem()
implant.simulate_stress_event()
